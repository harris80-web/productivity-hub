{
  "functions": {
    "api/*.php": { "runtime": "vercel-php@0.7.2" }
  },
  "routes": [
    { "src": "/api/(.*\\.php)", "dest": "/api/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/(.*\\.php)", "dest": "/$1" },
    { "src": "/", "dest": "/index.php" },   
    { "src": "/(.*)", "dest": "/$1" }
  ]
}